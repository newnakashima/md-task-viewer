{
  "name": "md-task-viewer",
  "version": "0.1.5",
  "description": "Launch a local task viewer/editor for markdown files with frontmatter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/newnakashima/md-task-viewer.git"
  },
  "homepage": "https://github.com/newnakashima/md-task-viewer",
  "bugs": "https://github.com/newnakashima/md-task-viewer/issues",
  "keywords": [
    "markdown",
    "task",
    "viewer",
    "frontmatter",
    "kanban"
  ],
  "type": "module",
  "bin": {
    "md-task-viewer": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsup",
    "build:client": "vite build",
    "dev:client": "vite",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "start:local": "npm run build && node dist/cli.js",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fastify/static": "^9.0.0",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.4",
    "gray-matter": "^4.0.3",
    "open": "^11.0.0",
    "picomatch": "^4.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.0.0",
    "@types/picomatch": "^4.0.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "dompurify": "^3.3.3",
    "marked": "^17.0.5",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
