{
  "name": "md-task-viewer",
  "version": "0.1.0",
  "description": "Launch a local task viewer/editor for markdown files with frontmatter",
  "type": "module",
  "bin": {
    "md-task-viewer": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsup",
    "build:client": "vite build",
    "dev:client": "vite",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "start:local": "npm run build && node dist/cli.js",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fastify/static": "^8.0.4",
    "chokidar": "^4.0.3",
    "fastify": "^5.2.1",
    "gray-matter": "^4.0.3",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
